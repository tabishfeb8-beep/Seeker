<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jet Lag: Seeker's Question Tracker</title>
    <style>
        * { box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: #1e272e; 
            color: white; 
            margin: 0; 
            padding: 0; 
            height: 100vh; 
            overflow: hidden; 
        }
        
        /* Layout Structure */
        .screen { display: flex; width: 100vw; height: 100vh; padding-top: 60px; }
        .left-panel { width: 28%; height: 100%; padding: 25px; border-right: 3px solid #718093; display: flex; flex-direction: column; justify-content: flex-start; overflow-y: auto; }
        .right-panel { width: 72%; height: 100%; padding: 25px; display: flex; flex-direction: column; justify-content: flex-start; overflow-y: auto; }
        
        /* Top Header Utilities */
        .top-navbar {
            position: fixed; top: 0; left: 0; width: 100vw; height: 60px;
            background: #2f3640; border-bottom: 3px solid #718093;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 20px; z-index: 900;
        }
        .header-title { font-size: 16px; font-weight: bold; color: #fbc531; letter-spacing: 1px; display: flex; align-items: center; gap: 10px; }
        
        /* Digital Clock Display */
        .navbar-session-timer {
            font-family: 'Courier New', Courier, monospace; background: #1e272e;
            color: #fbc531; border: 2px solid #718093; padding: 4px 12px;
            border-radius: 4px; font-size: 16px; font-weight: bold; box-shadow: inset 0 0 5px rgba(0,0,0,0.5);
        }

        h1 { color: #fbc531; margin: 0 0 5px 0; font-size: 26px; text-transform: uppercase; letter-spacing: 1px; }
        .subtitle { color: #a4b0be; font-style: italic; margin-bottom: 20px; font-size: 14px; }
        
        /* Stat Dashboard Widgets */
        .stat-box {
            background: #2f3640; border: 2px solid #718093; border-radius: 8px;
            padding: 15px; margin-bottom: 15px; text-align: left;
        }
        .stat-title { font-size: 11px; color: #a4b0be; text-transform: uppercase; font-weight: bold; margin-bottom: 5px; }
        .stat-value { font-size: 28px; font-weight: bold; color: #00ff66; font-family: monospace; }
        
        .stats-grid { display: grid; grid-template-columns: 1fr; gap: 6px; font-size: 12px; font-family: monospace; background: #1e272e; padding: 10px; border-radius: 6px; }
        .stat-row { display: flex; justify-content: space-between; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 3px; }
        .stat-label { color: #a4b0be; }
        .stat-num { color: #fbc531; font-weight: bold; }

        /* Logger Box */
        .logger-box {
            background: #1e272e; border: 1px solid #718093; border-radius: 6px;
            padding: 10px; flex-grow: 1; overflow-y: auto; text-align: left;
            font-size: 12px; font-family: monospace; color: #dcdde1; max-height: 200px;
        }
        .log-entry { border-bottom: 1px solid rgba(255,255,255,0.05); padding: 4px 0; }

        /* Section Headings */
        .section-header {
            font-size: 16px; color: #fbc531; font-weight: bold; text-transform: uppercase;
            margin: 20px 0 10px 0; border-bottom: 2px solid #718093; padding-bottom: 5px;
            display: flex; justify-content: space-between;
        }
        
